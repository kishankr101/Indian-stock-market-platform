# ========================
# Application Configuration
# ========================
APP_NAME=Indian Stock Market Platform
APP_ICON=📈
LAYOUT=wide
THEME=light

# ========================
# Database Configuration
# ========================
# Options: sqlite, postgresql
DB_ENGINE=sqlite
SQLITE_PATH=data/market_data.db

# PostgreSQL Configuration (uncomment if using PostgreSQL)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=stock_market
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# ========================
# API Configuration
# ========================
MARKET_DATA_API=yfinance
NEWS_API_KEY=your_news_api_key
STOCK_API_ENDPOINT=https://api.example.com

# ========================
# Authentication Configuration
# ========================
ENABLE_AUTH=false
SECRET_KEY=your-secret-key-change-in-production
SESSION_TIMEOUT=3600

# ========================
# Logging Configuration
# ========================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========================
# Feature Flags
# ========================
ENABLE_PAPER_TRADING=true
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_NEWS_MODULE=true
ENABLE_ADMIN_PANEL=false
